# features.grammar — Tests state vars, after, guards, actions, strings, comments

@lexer

state
    beg   = 1
    depth = 0

after
    beg = 0

tokens
    ident
    integer
    string_dq
    plus
    minus
    star
    assign
    comma
    colon
    lparen
    rparen
    arrow
    newline
    comment
    eof
    err

# Comments
'#' [^\n]*                                  → comment

# Strings
'"' ([^"\\$\n] | '\\' . | '$')* '"'         → string_dq

# Operators
'+'                                         → plus
'-'                                         → minus
'*'                                         → star
'='                                         → assign
','                                         → comma
':'                                         → colon
"->"                                        → arrow
'('                                         → lparen, {depth++}
')'                                         → rparen, {depth--}

# Newlines
'\n'                                        → newline, {beg = 1}

# Numbers and identifiers
[0-9]+                                      → integer
[a-zA-Z_][a-zA-Z0-9_]*                      → ident

# Fallback
.                                           → err

@parser

@lang = "features"

@conflicts = 0

name = IDENT

program! = body                             → (module ...1)
expr!    = expr                             → 1

body     = stmt                             → (1)
         | body NEWLINE stmt                → (...1 3)
         | body NEWLINE                     → 1

stmt     = expr

expr     = call "=" expr                    → (assign 1 3)
         | @infix

call     = call "(" args ")"                → (call 1 ...3)
         | atom

args     = L(expr)                          → (...1)
         |                                  → ()

atom     = name
         | INTEGER
         | STRING_DQ
         | "(" expr ")"                     → 2

@infix call
    "+" left, "-" left
    "*" left
