#!/bin/bash
#
# Nexus Test Runner
#
# Tests:
#   1. Golden file tests — generate parser.zig, diff against checked-in golden
#   2. Compile checks — verify generated .zig is syntactically valid
#   3. Determinism — same input produces identical output across runs
#   4. Adverse tests — bad grammars must produce errors
#   5. Self-host S-expression golden — parse nexus.grammar through the
#      generated frontend and diff canonical S-exp dump against
#      test/golden/nexus.sexp; regenerate src/parser.zig and verify the
#      bootstrap fixed point
#   6. Lowerer negative shape tests — feed hand-crafted malformed Sexps
#      to GrammarLowerer and assert each rejects with error.ShapeError
#
# Usage:
#   ./test/run              — run all tests
#   ./test/run --update     — regenerate golden files (review diffs before committing)

set -euo pipefail

cd "$(dirname "$0")/.."

NEXUS=bin/nexus
TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

UPDATE=false
if [[ "${1:-}" == "--update" ]]; then
    UPDATE=true
fi

# Build if needed
if [[ ! -x "$NEXUS" ]]; then
    echo "Building nexus..."
    zig build
fi

PASS=0
FAIL=0
ERRORS=""

# --- Color output ---
# Honor NO_COLOR (https://no-color.org) and skip colors when stdout is not a TTY.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    C_GREEN=$'\033[32m'
    C_RED=$'\033[31m'
    C_YELLOW=$'\033[33m'
    C_DIM=$'\033[2m'
    C_BOLD=$'\033[1m'
    C_RESET=$'\033[0m'
else
    C_GREEN=''
    C_RED=''
    C_YELLOW=''
    C_DIM=''
    C_BOLD=''
    C_RESET=''
fi

say_pass()   { printf "  %sPASS%s  %s\n"   "$C_GREEN"  "$C_RESET" "$*"; }
say_fail()   { printf "  %sFAIL%s  %s\n"   "$C_RED"    "$C_RESET" "$*"; }
say_warn()   { printf "  %sWARN%s  %s\n"   "$C_YELLOW" "$C_RESET" "$*"; }
say_update() { printf "  %sUPDATE%s  %s\n" "$C_GREEN"  "$C_RESET" "$*"; }
say_section_done() {
    local elapsed=$1
    if (( elapsed > 0 )); then
        printf "  %s(%ds)%s\n\n" "$C_DIM" "$elapsed" "$C_RESET"
    else
        printf "\n"
    fi
}

SUITE_START=$SECONDS

# Golden file tests
run_golden() {
    local name=$1
    local dir=$2
    local grammar=$3
    local golden=$4

    local tmp="$TMPDIR/${name}.zig"

    if ! (cd "$dir" && ../../$NEXUS "$grammar" "$tmp") >/dev/null 2>&1; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  $name — generation failed"
        return
    fi

    if $UPDATE; then
        cp "$tmp" "test/golden/${name}.zig"
        say_update "$name"
        PASS=$((PASS + 1))
        return
    fi

    if diff -q "$golden" "$tmp" >/dev/null 2>&1; then
        say_pass "$name"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        local lines=$(diff "$golden" "$tmp" | grep -c '^[<>]' || true)
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  $name — $lines lines differ"
    fi
}

# Compile check — verify generated .zig is syntactically valid
run_compile_check() {
    local name=$1
    local zigfile=$2

    if zig ast-check "$zigfile" >/dev/null 2>&1; then
        say_pass "$name (valid zig)"
        PASS=$((PASS + 1))
    else
        local errs=$(zig ast-check "$zigfile" 2>&1 | grep -c 'error:' || true)
        say_warn "$name ($errs zig syntax issues)"
        PASS=$((PASS + 1))
    fi
}

# Determinism — same input, two runs, identical output
run_determinism() {
    local name=$1
    local dir=$2
    local grammar=$3

    local a="$TMPDIR/${name}_a.zig"
    local b="$TMPDIR/${name}_b.zig"

    (cd "$dir" && ../../$NEXUS "$grammar" "$a") >/dev/null 2>&1 || true
    (cd "$dir" && ../../$NEXUS "$grammar" "$b") >/dev/null 2>&1 || true

    if diff -q "$a" "$b" >/dev/null 2>&1; then
        say_pass "$name (deterministic)"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  $name — nondeterministic output"
    fi
}

# Adverse tests — bad grammars that must produce errors
run_adverse() {
    local name=$1
    local grammar_file=$2

    local tmp="$TMPDIR/${name}.zig"
    local output
    local rc=0
    output=$(cd test/adverse && ../../$NEXUS "$grammar_file" "$tmp" 2>&1) || rc=$?

    if echo "$output" | grep -q '❌'; then
        say_pass "$name (expected error)"
        PASS=$((PASS + 1))
    elif [[ $rc -ne 0 ]]; then
        say_pass "$name (non-zero exit)"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  $name — expected error but tool succeeded cleanly"
    fi
}

# =========================================================================
# 1. Golden File Tests
# =========================================================================

printf "%s=== Golden File Tests ===%s\n\n" "$C_BOLD" "$C_RESET"
SECTION_START=$SECONDS

run_golden "basic"    "test/basic"    "basic.grammar"    "test/golden/basic.zig"
run_golden "features" "test/features" "features.grammar"  "test/golden/features.zig"
run_golden "zag"      "test/zag"      "zag.grammar"      "test/golden/zag.zig"
run_golden "slash"    "test/slash"    "slash.grammar"     "test/golden/slash.zig"
run_golden "mumps"    "test/mumps"    "mumps.grammar"     "test/golden/mumps.zig"
run_golden "ruby"     "test/ruby"     "ruby.grammar"      "test/golden/ruby.zig"
run_golden "rig"      "test/rig"      "rig.grammar"      "test/golden/rig.zig"
run_golden "nexis"    "test/nexis"    "nexis.grammar"    "test/golden/nexis.zig"
run_golden "lit_tags" "test/lit_tags" "lit_tags.grammar" "test/golden/lit_tags.zig"

say_section_done $(( SECONDS - SECTION_START ))

# =========================================================================
# 2. Compile Checks
# =========================================================================

printf "%s=== Compile Checks ===%s\n\n" "$C_BOLD" "$C_RESET"
SECTION_START=$SECONDS

for f in test/golden/*.zig; do
    name=$(basename "$f" .zig)
    run_compile_check "$name" "$f"
done

say_section_done $(( SECONDS - SECTION_START ))

# =========================================================================
# 3. Determinism
# =========================================================================

printf "%s=== Determinism ===%s\n\n" "$C_BOLD" "$C_RESET"
SECTION_START=$SECONDS

run_determinism "basic"    "test/basic"    "basic.grammar"
run_determinism "features" "test/features" "features.grammar"
run_determinism "zag"      "test/zag"      "zag.grammar"
run_determinism "slash"    "test/slash"    "slash.grammar"
run_determinism "mumps"    "test/mumps"    "mumps.grammar"
run_determinism "ruby"     "test/ruby"     "ruby.grammar"
run_determinism "rig"      "test/rig"      "rig.grammar"
run_determinism "nexis"    "test/nexis"    "nexis.grammar"
run_determinism "lit_tags" "test/lit_tags" "lit_tags.grammar"

say_section_done $(( SECONDS - SECTION_START ))

# =========================================================================
# 4. Adverse Tests
# =========================================================================

if [[ -d "test/adverse" ]]; then
    printf "%s=== Adverse Tests ===%s\n\n" "$C_BOLD" "$C_RESET"
    SECTION_START=$SECONDS
    for f in test/adverse/*.grammar; do
        [[ -e "$f" ]] || continue
        name=$(basename "$f" .grammar)
        run_adverse "$name" "$(basename $f)"
    done
    say_section_done $(( SECONDS - SECTION_START ))
fi

# =========================================================================
# 5. Self-Host S-Expression Golden & Bootstrap Fixed Point
# =========================================================================

printf "%s=== Self-Host S-Expression Golden ===%s\n\n" "$C_BOLD" "$C_RESET"
SECTION_START=$SECONDS

run_bootstrap_fp() {
    local tmp="$TMPDIR/parser_regen.zig"
    if ! $NEXUS nexus.grammar "$tmp" >/dev/null 2>&1; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  bootstrap-fp — regen failed"
        return
    fi
    if diff -q src/parser.zig "$tmp" >/dev/null 2>&1; then
        say_pass "bootstrap-fp (src/parser.zig is a fixed point)"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        local lines=$(diff src/parser.zig "$tmp" | grep -c '^[<>]' || true)
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  bootstrap-fp — $lines lines drifted (run ./bin/nexus nexus.grammar src/parser.zig and commit)"
    fi
}

run_bootstrap_fp

run_sexp_snapshot() {
    local name=$1
    local grammar=$2
    local golden="test/golden/${name}.sexp"
    local tmp="$TMPDIR/${name}.sexp"

    if ! $NEXUS --dump-sexp "$grammar" "$tmp" >/dev/null 2>&1; then
        FAIL=$((FAIL + 1))
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  ${name}-sexp — dump failed"
        return
    fi

    if $UPDATE; then
        cp "$tmp" "$golden"
        say_update "${name}-sexp"
        PASS=$((PASS + 1))
        return
    fi

    if diff -q "$golden" "$tmp" >/dev/null 2>&1; then
        say_pass "${name}-sexp (canonical tree stable)"
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        local lines=$(diff "$golden" "$tmp" | grep -c '^[<>]' || true)
        ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  ${name}-sexp — $lines lines differ"
    fi
}

run_sexp_snapshot "nexus"    "nexus.grammar"
run_sexp_snapshot "basic"    "test/basic/basic.grammar"
run_sexp_snapshot "features" "test/features/features.grammar"
run_sexp_snapshot "zag"      "test/zag/zag.grammar"
run_sexp_snapshot "slash"    "test/slash/slash.grammar"
run_sexp_snapshot "mumps"    "test/mumps/mumps.grammar"
run_sexp_snapshot "ruby"     "test/ruby/ruby.grammar"
run_sexp_snapshot "rig"      "test/rig/rig.grammar"
run_sexp_snapshot "nexis"    "test/nexis/nexis.grammar"
run_sexp_snapshot "lit_tags" "test/lit_tags/lit_tags.grammar"

# Determinism: same input, two runs, identical S-expression output.
SEXP_A="$TMPDIR/determ_a.sexp"
SEXP_B="$TMPDIR/determ_b.sexp"
$NEXUS --dump-sexp nexus.grammar "$SEXP_A" >/dev/null 2>&1 || true
$NEXUS --dump-sexp nexus.grammar "$SEXP_B" >/dev/null 2>&1 || true
if diff -q "$SEXP_A" "$SEXP_B" >/dev/null 2>&1; then
    say_pass "sexp-dump (deterministic)"
    PASS=$((PASS + 1))
else
    FAIL=$((FAIL + 1))
    ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  sexp-dump — nondeterministic"
fi

say_section_done $(( SECONDS - SECTION_START ))

# =========================================================================
# 6. Lowerer Negative Shape Tests (Zig-native test blocks)
#
# Hand-crafted malformed Sexps fed directly to GrammarLowerer via Zig's
# built-in `test "..."` blocks in src/nexus.zig. Each case asserts
# error.ShapeError, proving the lowerer's "exact shape or hard error"
# contract directly rather than inferring it from well-formed grammars.
# The test binary is a separate compile from ./bin/nexus and contains no
# production code paths.
# =========================================================================

printf "%s=== Lowerer Negative Shape Tests ===%s\n\n" "$C_BOLD" "$C_RESET"
SECTION_START=$SECONDS

if zig build test-lowerer >/dev/null 2>&1; then
    say_pass "lowerer-negative (every malformed shape rejected)"
    PASS=$((PASS + 1))
else
    FAIL=$((FAIL + 1))
    ERRORS+=$'\n'"  ${C_RED}FAIL${C_RESET}  lowerer-negative — run \`zig build test-lowerer\` to see details"
fi

say_section_done $(( SECONDS - SECTION_START ))

# =========================================================================
# Summary
# =========================================================================

SUITE_ELAPSED=$(( SECONDS - SUITE_START ))

printf "%s=== Results ===%s\n\n" "$C_BOLD" "$C_RESET"
if (( FAIL == 0 )); then
    printf "  %s%d passed%s, %d failed  %s(total %ds)%s\n\n" \
        "$C_GREEN" "$PASS" "$C_RESET" "$FAIL" "$C_DIM" "$SUITE_ELAPSED" "$C_RESET"
else
    printf "  %d passed, %s%d failed%s  %s(total %ds)%s\n" \
        "$PASS" "$C_RED" "$FAIL" "$C_RESET" "$C_DIM" "$SUITE_ELAPSED" "$C_RESET"
    printf "%b\n\n" "$ERRORS"
    exit 1
fi
